                                value={data?.client_code}
                                error={errors}
                                id={"client_code"}
                            />
                            <CheckBox
                                yes={"ϛЃϵ"}
                                no={"ϖϴϼ"}
                                className={"div61 form-check-box"}
                                title={"ϞϽϺ"}
                                value={data.gender}
                                onChange={(e) => setData("gender", e)}
                            />
                            <CheckBox
                                className={"div10 form-check-box"}
                                title={"Ϡϴ϶ϷϳϴϼЂ ϡϯϳϵ-ϼϯ?"}
