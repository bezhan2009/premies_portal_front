                            />
                            <Input
                                className={"div23"}
                                placeholder={"ϠϯϸϽϼϯ"}
                                onChange={(e) => setData("district", e)}
                                value={data?.district}
                                error={errors}
                                id={"district"}
                            />
                            <Input
                                className={"div65"}
