                                value={data?.account_usd}
                                error={errors}
                                id={"account_usd"}
                                required={true}
                            />
                            <Input
                                className={"div32"}
                                placeholder={"ϠЇϴЂ EUR*"}
                                onChange={(e) => setData("account_eur", e)}
                                value={data?.account_eur}
