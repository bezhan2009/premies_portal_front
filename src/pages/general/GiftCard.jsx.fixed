                                onChange={(e) => setData("issued_by", e)}
                                value={data?.issued_by}
                                error={errors}
                                id={"issued_by"}
                            />
                            <Input
                                className={"div17"}
                                placeholder={"�ϜϜ"}
                                onChange={(e) => setData("inn", e)}
                                value={data?.inn}
                                error={errors}
                                id={"inn"}
                            />
                            <Input
                                className={"div57"}
                                placeholder={"ϠЂЀϯϼϯ"}
                                onChange={(e) => setData("country", e)}
                                value={data?.country}
                                error={errors}
                                id={"country"}
                            />
                            <Select
