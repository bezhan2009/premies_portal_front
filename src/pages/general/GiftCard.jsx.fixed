                                error={errors}
                            />
                            <Input
                                className={"div12"}
                                placeholder={"ϠϴЀϷЏ"}
                                onChange={(e) => setData("documents_series", e)}
                                value={data?.documents_series}
                                error={errors}
                                id={"documents_series"}
                            />
                            <Input
                                className={"div13"}
                                placeholder={"ϜϽϻϴЀ"}
                                onChange={(e) => setData("document_number", e)}
                                value={data?.document_number}
                                error={errors}
                                id={"document_number"}
                            />
                            <Input
                                type="date"
                                className={"div14"}
                                placeholder={"ϔϯЂϯ ϱЋϳϯЇϷ"}
