                                id={"client_index"}
                            />
                            <Input
                                className={"div36"}
                                placeholder={"ϞЀϽϳЃϹЂ"}
                                onChange={(e) => setData("product", e)}
                                value={data?.product}
                                error={errors}
                                id={"product"}
                                required={true}
                            />
                            <Input
                                className={"div31"}
                                placeholder={"ϠЇϴЂ USD*"}
