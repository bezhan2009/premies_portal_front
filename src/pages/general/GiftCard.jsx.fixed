                                onChange={(e) => setData("regin_type", e)}
                                options={reginTypes}
                                error={errors}
                            />
                            <Input
                                className={"div19"}
                                placeholder={"ϠϴϲϷϽϼ"}
                                onChange={(e) => setData("region", e)}
                                value={data?.region}
                                error={errors}
                                id={"region"}
                            />
                            <Select
                                className={"div20"}
                                id={"population_type"}
                                value={data?.population_type}
                                onChange={(e) => setData("population_type", e)}
                                options={USTypes}
                                error={errors}
                            />
                            <Input
                                className={"div21"}
                                placeholder={"ϜϯЁ ϾЃϼϹЂ"}
                                onChange={(e) => setData("populated", e)}
                                value={data?.populated}
