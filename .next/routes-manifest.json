{
  "version": 3,
  "pages404": true,
  "appType": "hybrid",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/agent/applications/[id]/operator",
      "regex": "^/api/agent/applications/([^/]+?)/operator(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/agent/applications/(?<nxtPid>[^/]+?)/operator(?:/)?$"
    },
    {
      "page": "/api/backend/[...path]",
      "regex": "^/api/backend/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/backend/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/api/processing/transactions/[ids]",
      "regex": "^/api/processing/transactions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPids": "nxtPids"
      },
      "namedRegex": "^/api/processing/transactions/(?<nxtPids>[^/]+?)(?:/)?$"
    },
    {
      "page": "/processing/transactions/[ids]",
      "regex": "^/processing/transactions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPids": "nxtPids"
      },
      "namedRegex": "^/processing/transactions/(?<nxtPids>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[...path]",
      "regex": "^/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/(?<nxtPpath>.+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
